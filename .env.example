# ─── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── Bot Behaviour ─────────────────────────────────────────
ENABLE_DEBUG=False
LOG_LEVEL=INFO

# ─── Database ──────────────────────────────────────────────
DATABASE_PATH=data/signals.db

# ─── Scanner / Alerts ──────────────────────────────────────
# How often the background scanner runs (minutes)
SCAN_INTERVAL_MINUTES=30
# How many top coins to scan
TOP_COINS_SCAN_LIMIT=100
# Cooldown: don't re-alert same coin+action for N hours
ALERT_COOLDOWN_HOURS=6
# Only fire a signal if confidence is >= this value
CONFIDENCE_THRESHOLD=65

# ─── Environment ───────────────────────────────────────────
ENVIRONMENT=production
